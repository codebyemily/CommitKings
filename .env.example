# Supabase — copy to .env.local and fill in from:
# Dashboard → Project Settings → API (Legacy: Project URL + anon key; or API Keys → Publishable)

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Use one of these (anon is the classic name; publishable is the newer key type):
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-only (never expose to the browser) — only for admin scripts / webhooks:
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
